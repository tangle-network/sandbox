{
  "openapi": "3.0.0",
  "info": {
    "title": "Tangle Sandbox API",
    "version": "0.1.0",
    "description": "Public API contract for the Tangle Sandbox SDK"
  },
  "servers": [
    {
      "url": "https://api.sandbox.tangle.network"
    }
  ],
  "components": {
    "schemas": {
      "SandboxResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "provisioning",
              "running",
              "stopped",
              "failed",
              "deleted"
            ]
          },
          "connection": {
            "type": "object",
            "properties": {
              "sidecarUrl": {
                "type": "string"
              },
              "authToken": {
                "type": "string"
              },
              "authTokenExpiresAt": {
                "type": "string"
              },
              "ssh": {
                "type": "object",
                "properties": {
                  "host": {
                    "type": "string"
                  },
                  "port": {
                    "type": "number"
                  },
                  "username": {
                    "type": "string"
                  }
                },
                "required": [
                  "host",
                  "port",
                  "username"
                ]
              },
              "webTerminalUrl": {
                "type": "string"
              }
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "createdAt": {
            "type": "string"
          },
          "startedAt": {
            "type": "string"
          },
          "lastActivityAt": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "status",
          "createdAt"
        ],
        "additionalProperties": {
          "nullable": true
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "CreateSandboxRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "driver": {
            "$ref": "#/components/schemas/DriverConfig"
          },
          "image": {
            "type": "string"
          },
          "git": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "ref": {
                "type": "string"
              },
              "depth": {
                "type": "integer",
                "minimum": 0,
                "exclusiveMinimum": true
              },
              "sparse": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "auth": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string"
                  }
                }
              }
            },
            "required": [
              "url"
            ]
          },
          "bare": {
            "type": "boolean"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "resources": {
            "type": "object",
            "properties": {
              "cpu": {
                "type": "number"
              },
              "memoryMb": {
                "type": "number"
              },
              "storageMb": {
                "type": "number"
              }
            }
          },
          "backend": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "opencode"
                ]
              },
              "provider": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "apiKey": {
                "type": "string"
              },
              "baseUrl": {
                "type": "string"
              },
              "mode": {
                "type": "string",
                "enum": [
                  "api",
                  "cli"
                ]
              }
            }
          },
          "sshEnabled": {
            "type": "boolean"
          },
          "sshPublicKey": {
            "type": "string"
          },
          "webTerminalEnabled": {
            "type": "boolean"
          },
          "maxLifetimeSeconds": {
            "type": "number"
          },
          "idleTimeoutSeconds": {
            "type": "number"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "storage": {
            "$ref": "#/components/schemas/StorageConfig"
          },
          "fromSnapshot": {
            "type": "string"
          }
        },
        "additionalProperties": {
          "nullable": true
        }
      },
      "DriverConfig": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "docker",
              "firecracker",
              "host-agent",
              "tangle"
            ]
          }
        },
        "required": [
          "type"
        ]
      },
      "StorageConfig": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "s3",
              "gcs",
              "r2"
            ]
          },
          "bucket": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "credentials": {
            "type": "object",
            "properties": {
              "accessKeyId": {
                "type": "string"
              },
              "secretAccessKey": {
                "type": "string"
              }
            },
            "required": [
              "accessKeyId",
              "secretAccessKey"
            ]
          },
          "prefix": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "bucket",
          "credentials"
        ]
      },
      "DriverInfo": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "docker",
              "firecracker",
              "host-agent",
              "tangle"
            ]
          },
          "available": {
            "type": "boolean"
          },
          "version": {
            "type": "string"
          },
          "capabilities": {
            "type": "object",
            "properties": {
              "criu": {
                "type": "boolean"
              },
              "gpu": {
                "type": "boolean"
              },
              "vsock": {
                "type": "boolean"
              },
              "snapshots": {
                "type": "boolean"
              },
              "userManagement": {
                "type": "boolean"
              },
              "networkIsolation": {
                "type": "boolean"
              }
            },
            "required": [
              "criu",
              "gpu",
              "vsock",
              "snapshots",
              "userManagement",
              "networkIsolation"
            ]
          },
          "hosts": {
            "type": "number"
          },
          "capacity": {
            "type": "object",
            "properties": {
              "available": {
                "type": "number"
              },
              "total": {
                "type": "number"
              }
            },
            "required": [
              "available",
              "total"
            ]
          }
        },
        "required": [
          "type",
          "available",
          "version",
          "capabilities"
        ],
        "additionalProperties": {
          "nullable": true
        }
      },
      "SnapshotResponse": {
        "type": "object",
        "properties": {
          "snapshotId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "number"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "snapshotId",
          "createdAt",
          "tags"
        ]
      },
      "SnapshotListResponse": {
        "type": "object",
        "properties": {
          "snapshots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "snapshotId": {
                  "type": "string"
                },
                "projectRef": {
                  "type": "string"
                },
                "createdAt": {
                  "type": "string"
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "paths": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "sizeBytes": {
                  "type": "number"
                }
              },
              "required": [
                "snapshotId",
                "projectRef",
                "createdAt",
                "tags"
              ]
            }
          }
        },
        "required": [
          "snapshots"
        ]
      },
      "BatchRequest": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "context": {
                  "type": "object",
                  "additionalProperties": {
                    "nullable": true
                  }
                },
                "timeoutMs": {
                  "type": "number"
                }
              },
              "required": [
                "id",
                "message"
              ]
            }
          },
          "timeoutMs": {
            "type": "number"
          },
          "scalingMode": {
            "type": "string",
            "enum": [
              "fastest",
              "balanced",
              "cheapest"
            ]
          },
          "persistent": {
            "type": "boolean"
          }
        },
        "required": [
          "tasks"
        ]
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "status"
        ],
        "additionalProperties": {
          "nullable": true
        }
      },
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "config": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          }
        },
        "required": [
          "message"
        ]
      },
      "UsageResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "orgId": {
                "type": "string"
              },
              "period": {
                "type": "string"
              },
              "sessionsCreated": {
                "type": "number"
              },
              "messagesSent": {
                "type": "number"
              },
              "computeMs": {
                "type": "number"
              },
              "activeSessionCount": {
                "type": "number"
              },
              "active_sandboxes": {
                "type": "number"
              },
              "compute_minutes_today": {
                "type": "number"
              },
              "api_calls_today": {
                "type": "number"
              }
            },
            "required": [
              "orgId",
              "period",
              "sessionsCreated",
              "messagesSent",
              "computeMs",
              "activeSessionCount",
              "active_sandboxes",
              "compute_minutes_today",
              "api_calls_today"
            ]
          }
        },
        "required": [
          "success",
          "data"
        ]
      },
      "SubscriptionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "data": {
            "type": "object",
            "properties": {
              "orgId": {
                "type": "string"
              },
              "plan": {
                "type": "string",
                "enum": [
                  "free",
                  "pro",
                  "enterprise"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "active",
                  "canceled",
                  "past_due"
                ]
              },
              "currentPeriodEnd": {
                "type": "number"
              },
              "limits": {
                "type": "object",
                "properties": {
                  "sessionsPerDay": {
                    "type": "number"
                  },
                  "maxConcurrent": {
                    "type": "number"
                  },
                  "computeMinutesPerDay": {
                    "type": "number"
                  }
                },
                "required": [
                  "sessionsPerDay",
                  "maxConcurrent",
                  "computeMinutesPerDay"
                ]
              }
            },
            "required": [
              "orgId",
              "plan",
              "status",
              "currentPeriodEnd",
              "limits"
            ]
          }
        },
        "required": [
          "success",
          "data"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/v1/sandboxes": {
      "post": {
        "summary": "Create a new sandbox",
        "tags": [
          "Sandboxes"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSandboxRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sandbox created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SandboxResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Driver not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Quota exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List all sandboxes",
        "tags": [
          "Sandboxes"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "provisioning",
                "running",
                "stopped",
                "failed",
                "deleted"
              ]
            },
            "required": false,
            "name": "status",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true
            },
            "required": false,
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List of sandboxes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sandboxes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SandboxResponse"
                      }
                    }
                  },
                  "required": [
                    "sandboxes"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/sandboxes/{id}": {
      "get": {
        "summary": "Get sandbox details",
        "tags": [
          "Sandboxes"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Sandbox ID"
            },
            "required": true,
            "description": "Sandbox ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Sandbox details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SandboxResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Driver not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Sandbox not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a sandbox",
        "tags": [
          "Sandboxes"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Sandbox ID"
            },
            "required": true,
            "description": "Sandbox ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Sandbox deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "success"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Driver not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Sandbox not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/sandboxes/{id}/driver": {
      "get": {
        "summary": "Get sandbox driver info",
        "tags": [
          "Sandboxes"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Sandbox ID"
            },
            "required": true,
            "description": "Sandbox ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Driver info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DriverInfo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Driver not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Sandbox not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
